# Базовый локальный .env
# Для продакшена сгенерируй новый SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-before-production

# Для локальной разработки = True, для продакшена = False.
DEBUG=True

# Домены через запятую.
ALLOWED_HOSTS=localhost,127.0.0.1

# Если сайт будет работать по HTTPS на публичном домене, добавь origins со схемой.
# Пример: https://hammergym.pythonanywhere.com,https://demo.example.com
CSRF_TRUSTED_ORIGINS=

# Локальная временная зона проекта.
TIME_ZONE=Europe/Chisinau

# Настройки reverse proxy нужны для публичного HTTPS-деплоя.
TRUST_PROXY_SSL_HEADER=False
USE_X_FORWARDED_HOST=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# Email настройки.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=HAMMER GYM <no-reply@hammergym.com>
HAMMERGYM_ADMIN_EMAIL=admin@hammergym.com
